{
  "name": "@byelabel/react",
  "version": "0.0.1",
  "description": "ByeLabel React utilities (hooks, contexts)",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    },
    "./hooks": {
      "types": "./build/hooks/index.d.ts",
      "default": "./build/hooks/index.js"
    },
    "./contexts": {
      "types": "./build/contexts/index.d.ts",
      "default": "./build/contexts/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "build"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "license": "MIT",
  "author": "Orhan POLAT",
  "repository": {
    "type": "git",
    "url": "git@github.com:byelabel/helpers.git",
    "directory": "packages/react"
  },
  "keywords": [
    "react",
    "hooks",
    "context",
    "webim"
  ],
  "scripts": {
    "build": "rm -rf ./build && tsc --project tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^6.0.3"
  }
}
