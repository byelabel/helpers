{
  "name": "byelabel-helpers",
  "version": "1.0.0",
  "private": true,
  "description": "ByeLabel Helpers workspace",
  "author": "Orhan POLAT",
  "repository": "https://github.com/byelabel/helpers.git",
  "scripts": {
    "build": "pnpm -r --parallel run build",
    "dev": "pnpm -r --parallel run dev",
    "clean": "pnpm -r exec rm -rf build node_modules",
    "test": "pnpm -r run test",
    "test:watch": "pnpm -r --parallel run test:watch",
    "release:utils": "node scripts/release.mjs utils",
    "release:react": "node scripts/release.mjs react"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitest/ui": "^4.1.5",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
